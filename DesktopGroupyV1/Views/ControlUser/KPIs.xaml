<UserControl x:Class="DesktopGroupyV1.Views.ControlUser.KPIs"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:oxy="http://oxyplot.org/wpf"
             mc:Ignorable="d">

    <Grid Background="#F4F6F9">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Carte : Chiffre d'affaires -->
        <Border Grid.Column="0" Margin="10,10,5,8" CornerRadius="12" Padding="18,14">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#0063B1" Offset="0"/>
                    <GradientStop Color="#2196F3" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Border.Effect>
                <DropShadowEffect Color="#2196F3" BlurRadius="14" ShadowDepth="2" Opacity="0.30"/>
            </Border.Effect>
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="Chiffre d'affaires" FontSize="13" Foreground="#CCffffff"/>
                <TextBlock Text="{Binding ChiffreAffaire, StringFormat='{}{0:N2} €'}"
                           FontSize="26" FontWeight="Bold" Foreground="White" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- Carte : Préventes confirmées -->
        <Border Grid.Column="1" Margin="5,10,5,8" CornerRadius="12" Padding="18,14">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#1B7A3E" Offset="0"/>
                    <GradientStop Color="#28A745" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Border.Effect>
                <DropShadowEffect Color="#28A745" BlurRadius="14" ShadowDepth="2" Opacity="0.30"/>
            </Border.Effect>
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="Préventes confirmées" FontSize="13" Foreground="#CCffffff"/>
                <TextBlock Text="{Binding TotalPreventesConfirmes}"
                           FontSize="26" FontWeight="Bold" Foreground="White" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- Carte : Signalements -->
        <Border Grid.Column="2" Margin="5,10,10,8" CornerRadius="12" Padding="18,14">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#B71C1C" Offset="0"/>
                    <GradientStop Color="#E53935" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Border.Effect>
                <DropShadowEffect Color="#E53935" BlurRadius="14" ShadowDepth="2" Opacity="0.30"/>
            </Border.Effect>
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="Signalements reçus" FontSize="13" Foreground="#CCffffff"/>
                <TextBlock Text="{Binding SignalCount}"
                           FontSize="26" FontWeight="Bold" Foreground="White" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- Graphique -->
        <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3"
                Margin="10,0,10,10" CornerRadius="12" Background="White">
            <Border.Effect>
                <DropShadowEffect Color="#00000000" BlurRadius="10" ShadowDepth="2" Opacity="0.08"/>
            </Border.Effect>
            <oxy:PlotView Model="{Binding SalesPlotModel}"
                          Background="Transparent"
                          Margin="6"/>
        </Border>
    </Grid>
</UserControl>
