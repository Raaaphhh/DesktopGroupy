<UserControl x:Class="DesktopGroupyV1.Views.ControlUser.SignalementProduit"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:DesktopGroupyV1.Views.ControlUser"
             mc:Ignorable="d"
             d:DesignHeight="650" d:DesignWidth="900" Background="#F5F5F5">

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Titre -->
        <TextBlock Grid.Row="0"
                   Text="Signalements clients"
                   FontSize="24"
                   FontWeight="SemiBold"
                   Foreground="#2D2D2D"
                   Margin="0,0,0,20"/>

        <!-- Barre de filtre -->
        <Border Grid.Row="1"
                Background="White"
                CornerRadius="8"
                BorderBrush="#E0E0E0"
                BorderThickness="1"
                Padding="16,12"
                Margin="0,0,0,16">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="1" Opacity="0.08" Color="Black"/>
            </Border.Effect>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Filtrer par statut :"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Foreground="#495057"
                           VerticalAlignment="Center"
                           Margin="0,0,12,0"/>
                <ComboBox x:Name="FiltreStatut"
                          Width="180"
                          Height="34"
                          VerticalContentAlignment="Center"
                          SelectionChanged="FiltreStatut_SelectionChanged"/>
                <Border Background="#E3F2FD"
                        CornerRadius="12"
                        Padding="10,4"
                        Margin="16,0,0,0"
                        VerticalAlignment="Center">
                    <TextBlock x:Name="NbSignalementsLabel"
                               FontSize="13"
                               Foreground="#1565C0"
                               FontWeight="SemiBold"/>
                </Border>
            </StackPanel>
        </Border>

        <!-- DataGrid des signalements -->
        <Border Grid.Row="2"
                Background="White"
                CornerRadius="8"
                BorderBrush="#E0E0E0"
                BorderThickness="1"
                Margin="0,0,0,16">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="1" Opacity="0.08" Color="Black"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Background="#F8F9FA"
                        CornerRadius="8,8,0,0"
                        Padding="16,12"
                        BorderBrush="#E9ECEF"
                        BorderThickness="0,0,0,1">
                    <TextBlock Text="Liste des signalements"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="#495057"/>
                </Border>

                <DataGrid x:Name="GridSignalements"
                          Grid.Row="1"
                          ItemsSource="{Binding Signalements}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          SelectionMode="Single"
                          GridLinesVisibility="Horizontal"
                          HeadersVisibility="Column"
                          CanUserResizeRows="False"
                          Background="Transparent"
                          BorderThickness="0"
                          RowBackground="White"
                          AlternatingRowBackground="#FAFAFA"
                          HorizontalGridLinesBrush="#F0F0F0"
                          ColumnHeaderHeight="40"
                          RowHeight="52"
                          SelectionChanged="GridSignalements_SelectionChanged">
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="#868E96"/>
                            <Setter Property="FontSize" Value="12"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Padding" Value="12,0"/>
                            <Setter Property="BorderThickness" Value="0"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.CellStyle>
                        <Style TargetType="DataGridCell">
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Padding" Value="12,0"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="DataGridCell">
                                        <Border Background="{TemplateBinding Background}"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#EBF3FB"/>
                                    <Setter Property="Foreground" Value="#2D2D2D"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.CellStyle>
                    <DataGrid.Columns>

                        <!-- Client -->
                        <DataGridTemplateColumn Header="Client" Width="170">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Client.NomComplet}"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   Foreground="#2D2D2D"/>
                                        <TextBlock Text="{Binding Client.Email}"
                                                   FontSize="11"
                                                   Foreground="#868E96"
                                                   Margin="0,2,0,0"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- Produit -->
                        <DataGridTextColumn Header="Produit"
                                            Binding="{Binding Produit.Nom}"
                                            Width="150">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontSize" Value="13"/>
                                    <Setter Property="Foreground" Value="#495057"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <!-- Motif -->
                        <DataGridTextColumn Header="Motif"
                                            Binding="{Binding Motif}"
                                            Width="130">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontSize" Value="13"/>
                                    <Setter Property="Foreground" Value="#495057"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <!-- Description -->
                        <DataGridTextColumn Header="Description"
                                            Binding="{Binding Description}"
                                            Width="*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontSize" Value="12"/>
                                    <Setter Property="Foreground" Value="#6C757D"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <!-- Date -->
                        <DataGridTextColumn Header="Date"
                                            Binding="{Binding DateSignalement, StringFormat=dd/MM/yyyy}"
                                            Width="100">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontSize" Value="12"/>
                                    <Setter Property="Foreground" Value="#6C757D"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <!-- Statut avec badge coloré -->
                        <DataGridTemplateColumn Header="Statut" Width="120">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border x:Name="StatutBadge"
                                            CornerRadius="12"
                                            Padding="10,4"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Center"
                                            Background="#FFF3E0">
                                        <TextBlock x:Name="StatutText"
                                                   Text="{Binding Statut}"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"
                                                   Foreground="#E65100"/>
                                    </Border>
                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding Statut}" Value="résolu">
                                            <Setter TargetName="StatutBadge" Property="Background" Value="#E8F5E9"/>
                                            <Setter TargetName="StatutText" Property="Foreground" Value="#2E7D32"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Statut}" Value="rejeté">
                                            <Setter TargetName="StatutBadge" Property="Background" Value="#FFEBEE"/>
                                            <Setter TargetName="StatutText" Property="Foreground" Value="#C62828"/>
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <!-- Barre d'actions -->
        <Border Grid.Row="3"
                Background="White"
                CornerRadius="8"
                BorderBrush="#E0E0E0"
                BorderThickness="1"
                Padding="16,12">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="1" Opacity="0.08" Color="Black"/>
            </Border.Effect>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock x:Name="ActionLabel"
                           Text="Sélectionner un signalement pour agir"
                           FontSize="13"
                           Foreground="#868E96"
                           VerticalAlignment="Center"
                           Margin="0,0,16,0"/>
                <Button x:Name="BtnResoudre"
                        Content="Marquer résolu"
                        Height="36"
                        Padding="16,0"
                        FontSize="13"
                        FontWeight="SemiBold"
                        Foreground="White"
                        BorderThickness="0"
                        IsEnabled="False"
                        Cursor="Hand"
                        Click="BtnResoudre_Click"
                        Margin="0,0,8,0">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#2E7D32"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="6"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#388E3C"/>
                                            </Trigger>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter Property="Background" Value="#B0BEC5"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
                <Button x:Name="BtnRejeter"
                        Content="Rejeter"
                        Height="36"
                        Padding="16,0"
                        FontSize="13"
                        FontWeight="SemiBold"
                        Foreground="White"
                        BorderThickness="0"
                        IsEnabled="False"
                        Cursor="Hand"
                        Click="BtnRejeter_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#C62828"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="6"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#D32F2F"/>
                                            </Trigger>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter Property="Background" Value="#B0BEC5"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
