<UserControl x:Class="DesktopGroupyV1.Views.ControlUser.Stock"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:DesktopGroupyV1.Views.ControlUser"
             mc:Ignorable="d"
             d:DesignHeight="650" d:DesignWidth="900"
             Background="#F5F5F5">

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Titre -->
        <TextBlock Grid.Row="0"
                   Text="Stock des produits"
                   FontSize="24"
                   FontWeight="SemiBold"
                   Foreground="#2D2D2D"
                   Margin="0,0,0,20"/>

        <!-- Barre d'action : modifier le seuil -->
        <Border Grid.Row="1"
                Background="White"
                CornerRadius="8"
                BorderBrush="#E0E0E0"
                BorderThickness="1"
                Padding="16,12"
                Margin="0,0,0,16">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="1" Opacity="0.08" Color="Black"/>
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Groupe : seuil -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Modifier le seuil d'alerte :"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="#495057"
                               VerticalAlignment="Center"
                               Margin="0,0,12,0"/>

                    <ComboBox x:Name="ListeProduits"
                              ItemsSource="{Binding ProduitsVendeur}"
                              DisplayMemberPath="Nom"
                              Width="180"
                              Height="34"
                              VerticalContentAlignment="Center"/>

                    <TextBox x:Name="SeuilInput"
                             Width="70"
                             Height="34"
                             Margin="10,0,0,0"
                             VerticalContentAlignment="Center"
                             Padding="8,0"
                             FontSize="13"
                             BorderBrush="#CED4DA"
                             BorderThickness="1"/>

                    <Button Content="Modifier"
                            Height="34"
                            Padding="16,0"
                            Margin="10,0,0,0"
                            FontSize="13"
                            FontWeight="SemiBold"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="ModifierSeuil">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#0063B1"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="6"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#2196F3"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>

                <!-- Bouton recharger -->
                <Button Grid.Column="1"
                        Content="Recharger"
                        Height="34"
                        Padding="16,0"
                        FontSize="13"
                        FontWeight="SemiBold"
                        Foreground="#495057"
                        BorderThickness="1"
                        Cursor="Hand"
                        Click="RechargerDatatable">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#F8F9FA"/>
                            <Setter Property="BorderBrush" Value="#CED4DA"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="6"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#E9ECEF"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </Border>

        <!-- Alertes de stock -->
        <Border Grid.Row="2"
                Margin="0,0,0,16"
                CornerRadius="8"
                BorderThickness="1"
                BorderBrush="#FFCC80"
                Padding="0">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Visible"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Alertes.Count}" Value="0">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <Border.Background>
                <SolidColorBrush Color="#FFF8E1"/>
            </Border.Background>
            <Border.Effect>
                <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.08" Color="Black"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0"
                        Background="#FFE082"
                        CornerRadius="8,8,0,0"
                        Padding="16,10">
                    <TextBlock Text="Alertes de stock"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="#E65100"/>
                </Border>
                <ItemsControl Grid.Row="1"
                              ItemsSource="{Binding Alertes}"
                              Margin="0">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="16,8" BorderBrush="#FFE082" BorderThickness="0,0,0,1">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="⚠"
                                               FontSize="13"
                                               Foreground="#E65100"
                                               Margin="0,0,8,0"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding}"
                                               FontSize="13"
                                               Foreground="#E65100"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </Border>

        <!-- DataGrid des stocks -->
        <Border Grid.Row="3"
                Background="White"
                CornerRadius="8"
                BorderBrush="#E0E0E0"
                BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="1" Opacity="0.08" Color="Black"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Background="#F8F9FA"
                        CornerRadius="8,8,0,0"
                        Padding="16,12"
                        BorderBrush="#E9ECEF"
                        BorderThickness="0,0,0,1">
                    <TextBlock Text="Liste des produits et stocks"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="#495057"/>
                </Border>

                <DataGrid x:Name="ListeProduitsStocks"
                          Grid.Row="1"
                          ItemsSource="{Binding Stocks}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          SelectionMode="Single"
                          GridLinesVisibility="Horizontal"
                          HeadersVisibility="Column"
                          CanUserResizeRows="False"
                          Background="Transparent"
                          BorderThickness="0"
                          RowBackground="White"
                          AlternatingRowBackground="#FAFAFA"
                          HorizontalGridLinesBrush="#F0F0F0"
                          ColumnHeaderHeight="40"
                          RowHeight="48">
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="#868E96"/>
                            <Setter Property="FontSize" Value="12"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Padding" Value="12,0"/>
                            <Setter Property="BorderThickness" Value="0"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.CellStyle>
                        <Style TargetType="DataGridCell">
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Padding" Value="12,0"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="DataGridCell">
                                        <Border Background="{TemplateBinding Background}"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#EBF3FB"/>
                                    <Setter Property="Foreground" Value="#2D2D2D"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.CellStyle>
                    <DataGrid.Columns>

                        <DataGridTextColumn Header="Nom" Binding="{Binding Produit.Nom}" Width="*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontSize" Value="13"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="Foreground" Value="#2D2D2D"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Prix Initial" Binding="{Binding Produit.PrixInitial, StringFormat='{}{0:N2} €'}" Width="*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontSize" Value="13"/>
                                    <Setter Property="Foreground" Value="#495057"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Prix Groupé" Binding="{Binding Produit.PrixGroupe, StringFormat='{}{0:N2} €'}" Width="*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontSize" Value="13"/>
                                    <Setter Property="Foreground" Value="#495057"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Min Acheteurs" Binding="{Binding Produit.NombreMinAcheteurs}" Width="*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontSize" Value="13"/>
                                    <Setter Property="Foreground" Value="#495057"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Date Limite" Binding="{Binding Produit.DateLimite, StringFormat=dd/MM/yyyy}" Width="*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontSize" Value="12"/>
                                    <Setter Property="Foreground" Value="#6C757D"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <!-- Stock Physique avec badge coloré si bas -->
                        <DataGridTemplateColumn Header="Stock Physique" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding StockPhysique}"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               Foreground="#2D2D2D"
                                               VerticalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="Stock Réservé" Binding="{Binding StockReserve}" Width="*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontSize" Value="13"/>
                                    <Setter Property="Foreground" Value="#495057"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <!-- Seuil Alerte avec badge orange -->
                        <DataGridTemplateColumn Header="Seuil Alerte" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="12"
                                            Padding="10,4"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Center"
                                            Background="#FFF3E0">
                                        <TextBlock Text="{Binding SeuilAlerte}"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"
                                                   Foreground="#E65100"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
